# Django settings
# DEBUG=True
# SECRET_KEY="your_secret_key_here"
# DJANGO_LANGUAGE_CODE="en-us"
# ADMIN_USERNAME="something_unexpected"
# ADMIN_PASSWORD="change_me_at_least_20_characters"
# ADMIN_URL=not-standart-url

# Local Development Database (SQLite)
# DATABASE_URL="sqlite:///db.sqlite3"

# Local Development Database (PostgreSQL)
# DATABASE_URL=postgresql://user:password@db:5432/dbname

# Docker / Production Database settings
# POSTGRES_DB=taskman_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_PORT=5432

# Доверенные прокси - nginx на хосте и шлюз Docker
# Узнать IP шлюза: docker network inspect taskman_default | grep Gateway
# TRUSTED_PROXIES=127.0.0.1,172.19.0.1

# Rollbar / External Services
# POST_SERVER_ITEM_ACCESS_TOKEN=your_token_here